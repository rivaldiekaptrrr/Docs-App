# Environment Configuration Example
# Copy this file to .env and update the values

# Application Environment
# development | production
NODE_ENV=development

# Server Port
PORT=3000

# Database Connection
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/rndhub

# JWT Secret Key
# Generate a secure random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Upload Directory
# Relative or absolute path for file uploads
UPLOAD_DIR=../uploads

# CORS Origins
# Development: Auto-detects localhost and local network IPs (192.168.x.x, 10.x.x.x, etc.)
# Production: Specify exact domains (comma-separated for multiple)
# Examples:
#   Development: CORS_ORIGIN=http://localhost:5173
#   Production:  CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:5173
